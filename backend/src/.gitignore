# =============================================
# VIDAMEDIA - .gitignore
# Backend (Node.js/TypeScript) + Frontend (Ionic/Angular)
# =============================================

# ─── Dependencias ───────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
package-lock.json
yarn.lock

# ─── Archivos compilados ────────────────────────
dist/
backend/dist/
frontend/dist/
frontend/www/
build/
*.js
*.js.map
*.d.ts
*.tsbuildinfo

# ─── Archivos de entorno y credenciales ────────
.env
.env.local
.env.*.local
*.pem
*.key
*.crt

# ─── Logs y archivos temporales ────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
*.pid
*.seed
*.pid.lock

# ─── Sistemas operativos ────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ─── IDEs y editores ────────────────────────────
.vscode/
.idea/
*.iml
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ─── Configuraciones locales de VS Code ────────
.vscode/settings.json
.vscode/extensions.json
.vscode/launch.json

# ─── Ionic / Angular ────────────────────────────
frontend/.ionic/
frontend/.angular/
frontend/.sourcemaps/
frontend/coverage/
frontend/ionitron/
frontend/ionic.config.json.user

# ─── TypeORM ────────────────────────────────────
backend/src/migrations/*.js
backend/src/migrations/*.d.ts
backend/src/seeds/*.js
backend/src/seeds/*.d.ts

# ─── Pruebas y cobertura ────────────────────────
coverage/
.nyc_output/
*.test.js
*.spec.js
__tests__/

# ─── Docker ─────────────────────────────────────
docker-compose.override.yml
*.dockerignore

# ─── Otros ──────────────────────────────────────
*.tgz
*.gz
*.7z
*.rar
*.zip
.DS_Store